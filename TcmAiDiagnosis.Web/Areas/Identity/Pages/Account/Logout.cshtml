@page
@model TcmAiDiagnosis.Web.Areas.Identity.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "登出";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">用户登出</h3>
                </div>
                <div class="card-body text-center">
                    <p>正在为您登出...</p>
                    <form method="post">
                        <button type="submit" class="btn btn-primary">确认登出</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>