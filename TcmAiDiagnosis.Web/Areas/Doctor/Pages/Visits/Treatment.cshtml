@page
@using System.Text.Json
@model TcmAiDiagnosis.Web.Areas.Doctor.Pages.Visits.TreatmentModel
@{
    ViewData["Title"] = "AI治疗方案";
}

@functions {
    private static List<string> ParseJsonList(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return new List<string>();
        }

        try
        {
            return JsonSerializer.Deserialize<List<string>>(json) ?? new List<string>();
        }
        catch
        {
            return new List<string>();
        }
    }
}

@{
    var recommendedFormulas = ParseJsonList(Model.Syndrome?.RecommendedFormulas);
    var mainSymptoms = ParseJsonList(Model.Syndrome?.MainSymptoms);
    var commonDiseases = ParseJsonList(Model.Syndrome?.CommonDiseases);
    var syndromeCategories = ParseJsonList(Model.Syndrome?.SyndromeCategories);
    var relatedOrgans = ParseJsonList(Model.Syndrome?.RelatedOrgans);
    var treatment = Model.Treatment;
}

<div class="title-wrapper pt-30">
    <div class="row align-items-center">
        <div class="col-md-8">
            <div class="title">
                <h2>治疗方案</h2>
                <p class="text-muted mb-0">基于确认证候生成并展示真实治疗明细。</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="breadcrumb-wrapper d-flex justify-content-md-end gap-2 mt-3 mt-md-0">
                <button id="printButton" type="button" class="btn btn-outline-primary">打印</button>
                <form method="post" asp-page-handler="Regenerate" asp-route-visitId="@Model.VisitId" asp-route-syndromeId="@Model.SyndromeId">
                    <button type="submit" class="btn btn-success">重新生成AI方案</button>
                </form>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

<div class="card detail-card p-4 mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h4 class="mb-2 text-primary">@Model.Syndrome?.SyndromeName</h4>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge @Model.GetStatusBadgeClass()">@Model.GetStatusText()</span>
                @if (!string.IsNullOrWhiteSpace(treatment?.Version))
                {
                    <span class="badge bg-light text-dark">版本 @treatment.Version</span>
                }
                @if (Model.Syndrome != null)
                {
                    <span class="badge bg-primary">置信度 @Model.Syndrome.Confidence%</span>
                }
            </div>
        </div>
        <div class="text-muted">
            @if (treatment != null && treatment.CreatedAt != default)
            {
                <div>生成时间：@treatment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
            }
            @if (treatment?.UpdatedAt != null)
            {
                <div>更新时间：@treatment.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</div>
            }
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <p><strong>病机概要：</strong>@(Model.Syndrome?.PathogenesisAnalysis ?? treatment?.SyndromeAnalysis ?? "暂无")</p>
            <p><strong>治疗原则：</strong>@(treatment?.TreatmentPrinciple ?? Model.Syndrome?.TreatmentPrinciple ?? "暂无")</p>
            <p><strong>中医诊断：</strong>@(string.IsNullOrWhiteSpace(treatment?.TcmDiagnosis) ? "暂无" : treatment.TcmDiagnosis)</p>
        </div>
        <div class="col-md-6">
            <p><strong>预期效果：</strong>@(string.IsNullOrWhiteSpace(treatment?.ExpectedOutcome) ? "暂无" : treatment.ExpectedOutcome)</p>
            <p><strong>注意事项：</strong>@(string.IsNullOrWhiteSpace(treatment?.Precautions) ? "暂无" : treatment.Precautions)</p>
        </div>
    </div>

    @if (recommendedFormulas.Any() || mainSymptoms.Any() || syndromeCategories.Any() || relatedOrgans.Any() || commonDiseases.Any())
    {
        <div class="row mt-3">
            <div class="col-md-12">
                @if (recommendedFormulas.Any())
                {
                    <p>
                        <strong>推荐方剂：</strong>
                        @foreach (var item in recommendedFormulas)
                        {
                            <span class="badge bg-info text-dark me-1 mb-1">@item</span>
                        }
                    </p>
                }
                @if (mainSymptoms.Any())
                {
                    <p>
                        <strong>主要症状：</strong>
                        @foreach (var item in mainSymptoms)
                        {
                            <span class="badge bg-primary me-1 mb-1">@item</span>
                        }
                    </p>
                }
                @if (syndromeCategories.Any())
                {
                    <p>
                        <strong>证候分类：</strong>
                        @foreach (var item in syndromeCategories)
                        {
                            <span class="badge bg-success me-1 mb-1">@item</span>
                        }
                    </p>
                }
                @if (relatedOrgans.Any())
                {
                    <p>
                        <strong>归属脏腑：</strong>
                        @foreach (var item in relatedOrgans)
                        {
                            <span class="badge bg-warning text-dark me-1 mb-1">@item</span>
                        }
                    </p>
                }
                @if (commonDiseases.Any())
                {
                    <p>
                        <strong>常见疾病：</strong>
                        @foreach (var item in commonDiseases)
                        {
                            <span class="badge bg-danger me-1 mb-1">@item</span>
                        }
                    </p>
                }
            </div>
        </div>
    }
</div>

@if (Model.Treatment == null)
{
    <div class="alert alert-warning">当前还没有可展示的治疗方案。</div>
}
else
{
    <form method="post" asp-page-handler="Confirm" asp-route-visitId="@Model.VisitId" asp-route-syndromeId="@Model.SyndromeId" asp-route-treatmentId="@treatment!.Id">
    <div class="d-flex justify-content-end mb-3">
        <button type="submit" class="btn btn-primary">确认并保存所选方案</button>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card detail-card h-100 p-4">
                <div class="section-title-container">
                    <h5 class="section-title mb-0">中药处方</h5>
                </div>

                @if (Model.Treatment.Prescriptions.Any())
                {
                    @foreach (var prescription in Model.Treatment.Prescriptions)
                    {
                        <div class="mb-4">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedPrescriptionIds" value="@prescription.Id" checked />
                                <span class="form-check-label fw-semibold text-primary">@prescription.Name</span>
                            </label>
                            @if (!string.IsNullOrWhiteSpace(prescription.Description))
                            {
                                <p>@prescription.Description</p>
                            }
                            @if (prescription.Items.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-bordered table-sm">
                                        <thead>
                                            <tr>
                                                <th>药材</th>
                                                <th>用量</th>
                                                <th>单位</th>
                                                <th>炮制方法</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in prescription.Items)
                                            {
                                                <tr>
                                                    <td>@item.Name</td>
                                                    <td>@item.Dosage</td>
                                                    <td>@item.Unit</td>
                                                    <td>@(string.IsNullOrWhiteSpace(item.ProcessingMethod) ? "-" : item.ProcessingMethod)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            <p><strong>功效：</strong>@(string.IsNullOrWhiteSpace(prescription.Efficacy) ? "暂无" : prescription.Efficacy)</p>
                            <p><strong>主治：</strong>@(string.IsNullOrWhiteSpace(prescription.Indications) ? "暂无" : prescription.Indications)</p>
                            <p><strong>用法用量：</strong>@(string.IsNullOrWhiteSpace(prescription.Usage) ? "暂无" : prescription.Usage)</p>
                            @if (!string.IsNullOrWhiteSpace(prescription.Notes))
                            {
                                <p><strong>备注：</strong>@prescription.Notes</p>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">暂无中药处方数据。</p>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card detail-card h-100 p-4">
                <div class="section-title-container">
                    <h5 class="section-title mb-0">食疗方案</h5>
                </div>

                @if (Model.Treatment.DietaryTherapies.Any())
                {
                    @foreach (var therapy in Model.Treatment.DietaryTherapies)
                    {
                        <div class="food-therapy-item">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedDietaryTherapyIds" value="@therapy.Id" checked />
                                <span class="form-check-label fw-semibold">@therapy.Name</span>
                            </label>
                            @if (!string.IsNullOrWhiteSpace(therapy.Description))
                            {
                                <p>@therapy.Description</p>
                            }
                            @if (therapy.Ingredients.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-bordered table-sm">
                                        <thead>
                                            <tr>
                                                <th>食材</th>
                                                <th>用量</th>
                                                <th>处理方法</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ingredient in therapy.Ingredients)
                                            {
                                                <tr>
                                                    <td>@ingredient.Name</td>
                                                    <td>@ingredient.Dosage</td>
                                                    <td>@(string.IsNullOrWhiteSpace(ingredient.ProcessingMethod) ? "-" : ingredient.ProcessingMethod)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            <p><strong>功效：</strong>@(string.IsNullOrWhiteSpace(therapy.Efficacy) ? "暂无" : therapy.Efficacy)</p>
                            <p><strong>制作方法：</strong>@(string.IsNullOrWhiteSpace(therapy.Preparation) ? "暂无" : therapy.Preparation)</p>
                            <p><strong>服用方法：</strong>@(string.IsNullOrWhiteSpace(therapy.ServingMethod) ? "暂无" : therapy.ServingMethod)</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">暂无食疗方案数据。</p>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card detail-card h-100 p-4">
                <div class="section-title-container">
                    <h5 class="section-title mb-0">针灸与艾灸</h5>
                </div>

                @if (Model.Treatment.Acupunctures.Any())
                {
                    <h6 class="text-primary">针灸治疗</h6>
                    @foreach (var item in Model.Treatment.Acupunctures)
                    {
                        <div class="mb-3">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedAcupunctureIds" value="@item.Id" checked />
                                <span class="form-check-label"><strong>穴位：</strong>@item.PointName</span>
                            </label>
                            <p><strong>定位：</strong>@item.Location</p>
                            <p><strong>方法：</strong>@item.Method</p>
                            <p><strong>手法：</strong>@item.Technique</p>
                            <p><strong>频率：</strong>@item.Frequency</p>
                            <p><strong>留针时间：</strong>@item.Duration</p>
                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <p><strong>注意事项：</strong>@item.Notes</p>
                            }
                        </div>
                    }
                }

                @if (Model.Treatment.Moxibustions.Any())
                {
                    <h6 class="text-primary mt-4">艾灸治疗</h6>
                    @foreach (var item in Model.Treatment.Moxibustions)
                    {
                        <div class="mb-3">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedMoxibustionIds" value="@item.Id" checked />
                                <span class="form-check-label"><strong>穴位：</strong>@item.PointName</span>
                            </label>
                            <p><strong>方法：</strong>@item.Method</p>
                            <p><strong>材料：</strong>@item.MoxaType</p>
                            <p><strong>频率：</strong>@item.Frequency</p>
                            <p><strong>时长：</strong>@item.Duration</p>
                            @if (!string.IsNullOrWhiteSpace(item.Precautions))
                            {
                                <p><strong>注意事项：</strong>@item.Precautions</p>
                            }
                        </div>
                    }
                }

                @if (!Model.Treatment.Acupunctures.Any() && !Model.Treatment.Moxibustions.Any())
                {
                    <p class="text-muted mb-0">暂无针灸或艾灸数据。</p>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card detail-card h-100 p-4">
                <div class="section-title-container">
                    <h5 class="section-title mb-0">拔罐与生活方式</h5>
                </div>

                @if (Model.Treatment.Cuppings.Any())
                {
                    <h6 class="text-primary">拔罐治疗</h6>
                    @foreach (var item in Model.Treatment.Cuppings)
                    {
                        <div class="mb-3">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedCuppingIds" value="@item.Id" checked />
                                <span class="form-check-label"><strong>部位：</strong>@item.Area</span>
                            </label>
                            <p><strong>穴位：</strong>@item.SpecificPoints</p>
                            <p><strong>方法：</strong>@item.Method</p>
                            <p><strong>留罐时间：</strong>@item.Duration</p>
                            @if (!string.IsNullOrWhiteSpace(item.Precautions))
                            {
                                <p><strong>注意事项：</strong>@item.Precautions</p>
                            }
                        </div>
                    }
                }

                @if (Model.Treatment.LifestyleAdvices.Any())
                {
                    <h6 class="text-primary mt-4">生活方式建议</h6>
                    <ul>
                        @foreach (var item in Model.Treatment.LifestyleAdvices)
                        {
                            <li class="mb-3">
                                <label class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="SelectedLifestyleAdviceIds" value="@item.Id" checked />
                                    <span class="form-check-label fw-semibold">@item.Title</span>
                                </label>
                                <div>@item.Content</div>
                                @if (!string.IsNullOrWhiteSpace(item.Implementation))
                                {
                                    <div class="text-muted">实施方法：@item.Implementation</div>
                                }
                            </li>
                        }
                    </ul>
                }

                @if (!Model.Treatment.Cuppings.Any() && !Model.Treatment.LifestyleAdvices.Any())
                {
                    <p class="text-muted mb-0">暂无拔罐或生活方式数据。</p>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card detail-card h-100 p-4">
                <div class="section-title-container">
                    <h5 class="section-title mb-0">饮食建议</h5>
                </div>

                @if (Model.Treatment.DietaryAdvices.Any())
                {
                    @foreach (var advice in Model.Treatment.DietaryAdvices)
                    {
                        <div class="mb-4">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedDietaryAdviceIds" value="@advice.Id" checked />
                                <span class="form-check-label fw-semibold text-primary">@advice.Title</span>
                            </label>
                            <p><strong>饮食原则：</strong>@(string.IsNullOrWhiteSpace(advice.DietaryPrinciples) ? "暂无" : advice.DietaryPrinciples)</p>
                            <p><strong>用餐时间：</strong>@(string.IsNullOrWhiteSpace(advice.MealTiming) ? "暂无" : advice.MealTiming)</p>
                            <p><strong>烹饪方法：</strong>@(string.IsNullOrWhiteSpace(advice.CookingMethods) ? "暂无" : advice.CookingMethods)</p>
                            @if (advice.RecommendedFoods.Any())
                            {
                                <p>
                                    <strong>推荐食物：</strong>
                                    @foreach (var food in advice.RecommendedFoods)
                                    {
                                        <span class="badge bg-success me-1 mb-1">@food.FoodName</span>
                                    }
                                </p>
                            }
                            @if (advice.AvoidedFoods.Any())
                            {
                                <p>
                                    <strong>避免食物：</strong>
                                    @foreach (var food in advice.AvoidedFoods)
                                    {
                                        <span class="badge bg-danger me-1 mb-1">@food.FoodName</span>
                                    }
                                </p>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">暂无饮食建议数据。</p>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card detail-card h-100 p-4">
                <div class="section-title-container">
                    <h5 class="section-title mb-0">随访与安全提醒</h5>
                </div>

                @if (Model.Treatment.FollowUpAdvices.Any())
                {
                    <h6 class="text-primary">随访建议</h6>
                    @foreach (var advice in Model.Treatment.FollowUpAdvices)
                    {
                        <div class="mb-4">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedFollowUpAdviceIds" value="@advice.Id" checked />
                                <span class="form-check-label fw-semibold">@advice.Title</span>
                            </label>
                            <p><strong>时间：</strong>@advice.Timing</p>
                            <p><strong>目的：</strong>@advice.Purpose</p>
                            @if (advice.MonitoringIndicators.Any())
                            {
                                <p>
                                    <strong>监测指标：</strong>
                                    @foreach (var item in advice.MonitoringIndicators)
                                    {
                                        <span class="badge bg-info text-dark me-1 mb-1">@item.IndicatorName</span>
                                    }
                                </p>
                            }
                        </div>
                    }
                }

                @if (Model.Treatment.HerbalWarnings.Any())
                {
                    <h6 class="text-primary mt-4">中药安全警告</h6>
                    @foreach (var warning in Model.Treatment.HerbalWarnings)
                    {
                        <div class="alert alert-warning mb-3">
                            <label class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="SelectedHerbalWarningIds" value="@warning.Id" checked />
                                <span class="form-check-label fw-semibold">@warning.Title</span>
                            </label>
                            <div>@warning.Content</div>
                            @if (warning.AffectedMedications.Any())
                            {
                                <div class="mt-2">
                                    @foreach (var medication in warning.AffectedMedications)
                                    {
                                        <span class="badge bg-dark me-1 mb-1">@medication.MedicationName</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }

                @if (!Model.Treatment.FollowUpAdvices.Any() && !Model.Treatment.HerbalWarnings.Any())
                {
                    <p class="text-muted mb-0">暂无随访或安全提醒数据。</p>
                }
            </div>
        </div>
    </div>
    </form>
}

<script>
    document.getElementById('printButton')?.addEventListener('click', function () {
        window.print();
    });
</script>
