@page
@model TcmAiDiagnosis.Pages.Herb.IndexModel
@{
    ViewData["Title"] = "药材管理";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>药材管理</h2>
    <a href="/Herb/Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> 添加药材
    </a>
</div>

<!-- 搜索和筛选表单 -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control" name="searchKeyword" value="@Model.SearchKeyword"
                       placeholder="搜索药材名称、功效、性味...">
            </div>
            <div class="col-md-3">
                <select class="form-select" name="category">
                    <option value="">所有分类</option>
                    @if (Model.Categories != null)
                    {
                        foreach (var category in Model.Categories)
                        {
                            <option value="@category" selected="@(category == Model.SelectedCategory)">@category</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" name="toxicity">
                    <option value="">所有毒性</option>
                    <option value="0" selected="@(0 == Model.SelectedToxicity)">无毒</option>
                    <option value="1" selected="@(1 == Model.SelectedToxicity)">小毒</option>
                    <option value="2" selected="@(2 == Model.SelectedToxicity)">有毒</option>
                    <option value="3" selected="@(3 == Model.SelectedToxicity)">大毒</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">搜索</button>
            </div>
        </form>
    </div>
</div>

<!-- 操作提示 -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- 药材列表 -->
<div class="card">
    <div class="card-body">
        @if (Model.Herbs?.Items?.Any() == true)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>药材名称</th>
                            <th>性味</th>
                            <th>归经</th>
                            <th>功效</th>
                            <th>分类</th>
                            <th>毒性</th>
                            <th>状态</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var herb in Model.Herbs.Items)
                        {
                            <tr>
                                <td>
                                    <strong>@herb.HerbName</strong>
                                    @if (!string.IsNullOrEmpty(herb.Source))
                                    {
                                        <br>
                                        <small class="text-muted">来源: @herb.Source</small>
                                    }
                                </td>
                                <td>@(string.IsNullOrEmpty(herb.Properties) ? "-" : herb.Properties)</td>
                                <td>@(string.IsNullOrEmpty(herb.Meridians) ? "-" : herb.Meridians)</td>
                                <td title="@herb.Efficacy">
                                    @if (!string.IsNullOrEmpty(herb.Efficacy))
                                    {
                                        <span class="efficacy-text">
                                            @GetShortEfficacy(herb.Efficacy)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@(string.IsNullOrEmpty(herb.Category) ? "-" : herb.Category)</td>
                                <td>
                                    <span class="badge @GetToxicityBadgeClass(herb.ToxicityLevel)">
                                        @herb.ToxicityLevel
                                    </span>
                                </td>
                                <td>
                                    @if (herb.IsActive)
                                    {
                                        <span class="badge bg-success">启用</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">已删除</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Herb/Details/@herb.HerbId" class="btn btn-info" title="查看详情">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="/Herb/Edit/@herb.HerbId" class="btn btn-warning" title="编辑">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 分页信息 -->
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted">
                    显示第 @((Model.Herbs.Page - 1) * Model.Herbs.PageSize + 1) 到
                    @Math.Min(Model.Herbs.Page * Model.Herbs.PageSize, Model.Herbs.TotalCount) 条，
                    共 @Model.Herbs.TotalCount 条记录
                </div>

                <!-- 分页控件 -->
                @if (Model.Herbs.TotalCount > Model.Herbs.PageSize)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0">
                            @{
                                var totalPages = (int)Math.Ceiling((double)Model.Herbs.TotalCount / Model.Herbs.PageSize);
                                var currentPage = Model.Herbs.Page;
                                var maxPagesToShow = 5;
                                var startPage = Math.Max(1, currentPage - maxPagesToShow / 2);
                                var endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);
                                startPage = Math.Max(1, endPage - maxPagesToShow + 1);

                                // 上一页
                                if (currentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link"
                                           href="?pageNumber=@(currentPage - 1)&pageSize=@Model.Herbs.PageSize&searchKeyword=@Model.SearchKeyword&category=@Model.SelectedCategory&toxicity=@Model.SelectedToxicity">
                                            &laquo;
                                        </a>
                                    </li>
                                }

                                // 页码
                                for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link"
                                           href="?pageNumber=@i&pageSize=@Model.Herbs.PageSize&searchKeyword=@Model.SearchKeyword&category=@Model.SelectedCategory&toxicity=@Model.SelectedToxicity">
                                            @i
                                        </a>
                                    </li>
                                }

                                // 下一页
                                if (currentPage < totalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link"
                                           href="?pageNumber=@(currentPage + 1)&pageSize=@Model.Herbs.PageSize&searchKeyword=@Model.SearchKeyword&category=@Model.SelectedCategory&toxicity=@Model.SelectedToxicity">
                                            &raquo;
                                        </a>
                                    </li>
                                }
                            }
                        </ul>
                    </nav>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                <p class="text-muted">没有找到药材数据</p>
                <a href="/Herb/Create" class="btn btn-primary">添加第一个药材</a>
            </div>
        }
    </div>
</div>

@functions {
    string GetToxicityBadgeClass(string toxicityLevel)
    {
        return toxicityLevel?.ToLower() switch
        {
            "无毒" => "bg-success",
            "小毒" => "bg-warning",
            "有毒" => "bg-danger",
            "大毒" => "bg-dark",
            _ => "bg-secondary"
        };
    }

    string GetShortEfficacy(string efficacy)
    {
        if (string.IsNullOrEmpty(efficacy))
            return "-";

        var separators = new[] { '，', ',', '；', ';', '。', '.' };
        var firstEfficacy = efficacy.Split(separators, StringSplitOptions.RemoveEmptyEntries)
                                   .FirstOrDefault()?.Trim();

        if (!string.IsNullOrEmpty(firstEfficacy))
        {
            return firstEfficacy.Length > 15 ? firstEfficacy.Substring(0, 15) + "..." : firstEfficacy;
        }

        return efficacy.Length > 20 ? efficacy.Substring(0, 20) + "..." : efficacy;
    }
}

<style>
    .efficacy-text {
        cursor: help;
    }

    .table td {
        vertical-align: middle;
    }

    .badge {
        font-size: 0.75em;
    }
</style>

<script>
    // 自动隐藏提示消息
    document.addEventListener('DOMContentLoaded', function() {
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    });
</script>